{
  "name": "AI-Ready Dev Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/project",
  "postStartCommand": "for d in ~/.config ~/.local ~/.cache ~/.pi ~/.ssh; do sudo mkdir -p \"$d\"; sudo chown -R vscode:vscode \"$d\"; done; sudo mkdir -p /run/sshd && sudo /usr/sbin/sshd && chmod 700 ~/.ssh 2>/dev/null; chmod 600 ~/.ssh/authorized_keys 2>/dev/null; true",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "files.eol": "\n",
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "Anthropic.claude-code",
        "OpenAI.chatgpt",
        "Google.gemini-cli-vscode-ide-companion",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "editorconfig.editorconfig",
        "github.vscode-github-actions"
      ]
    }
  }
}
