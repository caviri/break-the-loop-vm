# Devcontainer credential persistence (keep dirs, ignore contents)
.devcontainer/persist/config/*
!.devcontainer/persist/config/.gitkeep
.devcontainer/persist/local-share/*
!.devcontainer/persist/local-share/.gitkeep
.devcontainer/persist/cache/*
!.devcontainer/persist/cache/.gitkeep
.devcontainer/persist/pi/*
!.devcontainer/persist/pi/.gitkeep
.devcontainer/persist/ssh/*
!.devcontainer/persist/ssh/.gitkeep
